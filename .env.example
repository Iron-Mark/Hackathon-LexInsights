# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/chat

# Supabase public client configuration
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the Supabase publishable key for Clerk Third-Party Auth.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible fallback while migrating older local env files.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Research provider mode
# local-providerless is the production default. Use remote-rag only when a reachable RAG provider is configured.
NEXT_PUBLIC_RAG_PROVIDER_MODE=local-providerless

# Optional remote RAG API backend
NEXT_PUBLIC_RAG_API_URL=https://devkada.resqlink.org
NEXT_PUBLIC_RAG_WS_URL=wss://devkada.resqlink.org
NEXT_PUBLIC_RAG_BACKEND_ISSUE_URL=https://github.com/Iron-Mark/Hackathon-LexInsights/issues/1

# Keep enabled unless the backend allows browser CORS directly.
NEXT_PUBLIC_USE_RAG_PROXY=true

# Maintainer-only diagnostic pages (/test-rag and /test-document).
# Keep false or unset in public production deployments.
ENABLE_DIAGNOSTIC_ROUTES=false
