{
  "name": "LexInsights",
  "version": "0.5.2",
  "description": "Philippine legal research and compliance assistant for chat, document review, providerless local RAG, and citation-supported compliance reports.",
  "private": true,
  "license": "UNLICENSED",
  "author": {
    "name": "Mark Siazon",
    "url": "https://www.marksiazon.dev"
  },
  "homepage": "https://lexiph.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iron-Mark/Hackathon-LexInsights.git"
  },
  "bugs": {
    "url": "https://github.com/Iron-Mark/Hackathon-LexInsights/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build-with-metadata.mjs",
    "start": "next start",
    "clean": "node scripts/clean-generated.mjs",
    "lint": "eslint",
    "check:docs": "node scripts/check-markdown-links.mjs",
    "check:docs:self-test": "node scripts/check-markdown-links-self-test.mjs",
    "check:readiness": "node scripts/check-readiness.mjs",
    "check:readiness:self-test": "node scripts/check-readiness-self-test.mjs",
    "check:live": "node scripts/check-live-deployment.mjs",
    "check:live:self-test": "node scripts/check-live-deployment-self-test.mjs",
    "check:deployment": "node scripts/check-deployment-preflight.mjs",
    "check:deployment:self-test": "node scripts/check-deployment-preflight-self-test.mjs",
    "check:rag-proxy:self-test": "node scripts/check-rag-proxy-self-test.mjs",
    "check:providerless:self-test": "node scripts/check-providerless-self-test.mjs",
    "check:local-rag:golden": "node scripts/check-local-rag-golden-self-test.mjs",
    "check:local-rag:answers": "node scripts/check-local-rag-answer-quality.mjs",
    "check:local-rag:sources": "node scripts/check-local-rag-source-freshness.mjs",
    "check:local-rag:performance": "node scripts/check-local-rag-performance-self-test.mjs",
    "check:local-rag:governance": "node scripts/check-local-rag-governance.mjs",
    "check:document-text:self-test": "node scripts/check-document-text-self-test.mjs",
    "check:document-extraction:self-test": "node scripts/check-document-extraction-self-test.mjs",
    "check:release": "node scripts/check-release-integrity.mjs",
    "check:release:tag": "node scripts/check-release-integrity.mjs --require-current-tag",
    "check:release:self-test": "node scripts/check-release-integrity-self-test.mjs",
    "check:pwa": "node scripts/check-pwa-readiness.mjs",
    "check:local": "npm run lint -- --max-warnings=0 && npx tsc --noEmit && npm audit --omit=dev && npm run check:docs:self-test && npm run check:docs && npm run check:readiness:self-test && npm run check:deployment:self-test && npm run check:live:self-test && npm run check:rag-proxy:self-test && npm run check:providerless:self-test && npm run check:local-rag:golden && npm run check:local-rag:answers && npm run check:local-rag:sources && npm run check:local-rag:performance && npm run check:local-rag:governance && npm run check:document-text:self-test && npm run check:document-extraction:self-test && npm run check:release:self-test && npm run check:release && npm run check:pwa && npm run build && npm run smoke:browser",
    "deploy:prod": "node scripts/deploy-vercel.mjs",
    "smoke:browser": "playwright test"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.80.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.553.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.9",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "word-extractor": "^1.0.4",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
